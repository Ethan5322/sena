{
    "name": "sena-ai-receptionist",
    "version": "0.1.0",
    "private": true,
    "description": "Sena — AI voice front-desk receptionist for hotels. Built by MuleSoo Digital Services.",
    "type": "commonjs",
    "scripts": {
        "call": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/live-test.ps1",
        "dev": "node scripts/dev-server.mjs",
        "voice": "docker compose --env-file .env.local up --build",
        "samples": "node scripts/render-sample.cjs",
        "test": "npm run test:db && npm run test:install && npm run test:router && npm run test:card && npm run test:tools && npm run test:e2e && npm run test:agent",
        "test:db": "node scripts/test-schema.mjs",
        "test:install": "node scripts/test-install.mjs",
        "test:router": "node scripts/test-router.mjs",
        "test:card": "node scripts/test-card.mjs",
        "test:tools": "node scripts/test-tools.mjs",
        "test:e2e": "node scripts/test-booking-e2e.mjs",
        "test:agent": "node scripts/test-agent.mjs",
        "test:voice": "node scripts/test-agent.mjs --voice",
        "build:install": "node scripts/build-install.mjs"
    },
    "devDependencies": {
        "@electric-sql/pglite": "^0.5.4",
        "pngjs": "^7.0.0"
    },
    "dependencies": {
        "jsbarcode": "^3.11.6",
        "jsqr": "^1.4.0",
        "nodemailer": "^9.0.3",
        "pg": "^8.22.0",
        "puppeteer-core": "^23.0.0",
        "qrcode": "^1.5.4"
    }
}
