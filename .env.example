# ============================================================================
# Sena — environment. Copy to .env.local for local work; set the same keys in
# the Vercel project for production. NOTHING here is committed: .env* is ignored.
#
# NEVER paste a real key into a chat, a commit, or a screenshot. If you do,
# revoke it and issue a new one — a leaked key is not "probably fine".
# ============================================================================

# ── Database ────────────────────────────────────────────────────────────────
# Supabase → Project Settings → Database → Connection string → URI.
# Use the POOLER (port 6543), not the direct one: each Vercel invocation opens
# its own connection, and the direct port runs out.
DATABASE_URL=postgresql://postgres.xxxx:PASSWORD@aws-0-eu-west-1.pooler.supabase.com:6543/postgres

# Which hotel answers when the dialled number is not matched to a sena_hotels
# row. For the demo line:  select id from sena_hotels where is_demo;
# In production leave this EMPTY — a hotel should be resolved by the number the
# guest actually dialled, never by a fallback.
SENA_DEFAULT_HOTEL_ID=

# Where this deployment is reachable. The guest's ID card link is built from it,
# so if it is wrong or empty the confirmation email carries a number the guest
# cannot show to a scanner.
SENA_PUBLIC_URL=https://your-app.vercel.app

# ── Email — how the booking actually reaches the guest ──────────────────────
# The payment link AND the guest's QR ID card both go by email. There is no
# WhatsApp and no SMS: Meta will not deliver a free-form message to someone who
# has not messaged you first, and a phone call does not open that window.
#
# Any SMTP server works. Free options, no subscription:
#
#   Gmail  — host smtp.gmail.com, port 587, user = your address,
#            pass = an APP PASSWORD (not your login password; turn on 2FA first,
#            then Google Account → Security → App passwords). ~500 mails/day.
#
#   Resend — host smtp.resend.com, port 587, user "resend",
#            pass = an API key. 3,000/month free, and lets you send from
#            bookings@mulesoo.com once you verify the domain.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Jacaranda Court Hotel <bookings@example.com>"

# ── Vapi ────────────────────────────────────────────────────────────────────
# Any long random string. Goes in Vapi's assistant as the Server Secret; Vapi
# sends it back on every tool call as the x-vapi-secret header. Without it, the
# tool endpoint is a public API for reserving a hotel's whole inventory and
# reading its guest list.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SENA_WEBHOOK_SECRET=

# The ElevenLabs VOICE id Sena speaks with — the voice, not an API key.
# (The ElevenLabs API key itself goes in the Vapi dashboard, not here.)
SENA_VOICE_ID=

# ── Paystack (ZAR) ──────────────────────────────────────────────────────────
# Test keys work immediately on signup — no business verification needed.
# The same key also verifies the webhook signature.
PAYSTACK_SECRET_KEY=sk_test_...
PAYSTACK_CALLBACK_URL=https://your-app.vercel.app/paid

# ── Supabase (front-desk scanner page only) ────────────────────────────────
# Project Settings → API. The ANON key is PUBLIC and safe to ship in the page:
# policies.sql grants it no policy at all, so it can read nothing. The clerk
# signs in with Supabase Auth, and the only thing they can then do is call
# sena_staff_check_in().
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=
