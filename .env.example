# ============================================================================
# Sena — environment. Copy to .env.local for local work; set the same keys in
# the Vercel project for production. NOTHING here is committed: .env* is ignored.
#
# NEVER paste a real key into a chat, a commit, or a screenshot. If you do,
# revoke it and issue a new one — a leaked key is not "probably fine".
# ============================================================================

# ── Database ────────────────────────────────────────────────────────────────
# Supabase → Project Settings → Database → Connection string → URI.
# Use the POOLER (port 6543), not the direct one: each Vercel invocation opens
# its own connection, and the direct port runs out.
DATABASE_URL=postgresql://postgres.xxxx:PASSWORD@aws-0-eu-west-1.pooler.supabase.com:6543/postgres

# Which hotel answers when the dialled number is not matched to a sena_hotels
# row. For the demo line:  select id from sena_hotels where is_demo;
# In production leave this EMPTY — a hotel should be resolved by the number the
# guest actually dialled, never by a fallback.
SENA_DEFAULT_HOTEL_ID=

# Where this deployment is reachable. The guest's ID card link is built from it,
# so if it is wrong or empty the confirmation email carries a number the guest
# cannot show to a scanner.
SENA_PUBLIC_URL=https://your-app.vercel.app

# ── Email — how the booking actually reaches the guest ──────────────────────
# The payment link AND the guest's QR ID card both go by email. There is no
# WhatsApp and no SMS: Meta will not deliver a free-form message to someone who
# has not messaged you first, and a phone call does not open that window.
#
# Any SMTP server works. Free options, no subscription:
#
#   Gmail  — host smtp.gmail.com, port 587, user = your address,
#            pass = an APP PASSWORD (not your login password; turn on 2FA first,
#            then Google Account → Security → App passwords). ~500 mails/day.
#
#   Resend — host smtp.resend.com, port 587, user "resend",
#            pass = an API key. 3,000/month free, and lets you send from
#            bookings@mulesoo.com once you verify the domain.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Jacaranda Court Hotel <bookings@example.com>"

# ── Owner WhatsApp (optional — email always goes out regardless) ─────────────
# Two providers; CallMeBot wins when both are set.
#
# CallMeBot (one hotel, zero paperwork): the owner sends the message
# "I allow callmebot to send me messages" to CallMeBot's number ONCE from
# their own WhatsApp (see callmebot.com/blog/free-api-whatsapp-messages/),
# gets an API key back, and every Sena alert lands on that phone. The key
# only ever delivers to its own phone.
CALLMEBOT_PHONE=
CALLMEBOT_APIKEY=

# Meta WhatsApp Cloud API (many hotels, a real business number):
# developers.facebook.com → your app → WhatsApp. Free tier covers ~1,000
# conversations/month. Plain-text alerts deliver only inside Meta's 24-hour
# reply window; for always-on delivery create a pre-approved utility template
# with one body variable (e.g. name it sena_alert, body "{{1}}") and set its
# name below. The receiving number is sena_hotels.escalation_whatsapp.
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_TEMPLATE_NAME=

# ── The voice stack — all of it self-hosted, none of it billed ──────────────
# There is no Vapi key, no ElevenLabs key and no Twilio key in this file any
# more, and that is the point. The voice agent runs in docker on your machine
# (docker-compose.yml): LiveKit carries the audio, faster-whisper listens, Piper
# speaks. The only meter running is Anthropic, and it was always running.

# What proves a tool call really came from OUR agent. The agent sends it on every
# request as the x-sena-secret header; api/sena/tool.mjs checks it in constant
# time. Without it, that endpoint is a public API for reserving a hotel's whole
# inventory and reading its guest list.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SENA_WEBHOOK_SECRET=

# ── The brain: paid-and-good, or free-and-slow ──────────────────────────────
# anthropic — Claude. The production brain and the ONLY paid thing in the stack.
#             Pay-as-you-go, no subscription: ~US$5 of credit (the minimum
#             top-up) covers roughly 10–30 full test calls.
# ollama    — a small model running free on your own machine, so the whole call
#             flow can be proven with NO API key. Be honest about what it is:
#             on a modest CPU each reply takes tens of seconds and a 1B model
#             fumbles tools. It proves the plumbing, never the product — do not
#             demo it to a client. Needs Ollama installed and a model pulled:
#             winget install Ollama.Ollama && ollama pull llama3.2:1b
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-...
OLLAMA_MODEL=llama3.2:1b

# ── LiveKit (webRTC — this is what replaced Twilio) ─────────────────────────
# The dev keys below match livekit.yaml and are PUBLIC — they are committed to
# this repo. They are fine on localhost and nowhere else: anyone holding them can
# mint a token and join any room on the server, including a call in progress.
# Before this faces a guest:  docker run --rm livekit/livekit-server generate-keys
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret-at-least-32-characters-long

# What the BROWSER is told to connect to. Not the container address — the guest's
# laptop cannot resolve "livekit". On a real server this is wss://your-host:7880.
LIVEKIT_PUBLIC_URL=ws://localhost:7880

# Where the agent finds the Node API (this repo's api/). Locally that is
# `npm run dev` on the host; in production it is your Vercel URL.
SENA_API_URL=http://host.docker.internal:3000

# Which origins may open a call. "*" is a prototype convenience — set it to the
# hotel's real site before a guest ever sees this.
SENA_ALLOWED_ORIGINS=*

# ── Whisper (STT) and Piper (TTS) — both local, both free ───────────────────
# Whisper: 'small' is the floor. 'base' mishears letters, and a guest spelling an
# email address to a model that hears "m" as "n" gets a booking that never
# arrives. 'medium' is better and roughly twice as slow — worth it on a GPU box.
WHISPER_MODEL=small

# The Piper voice, inside the container. Piper has NO South African English voice
# (only en_GB and en_US ship), so en_GB-cori-medium is the honest best fit: South
# African English is non-rhotic like British RP, so a British voice lands far
# closer than an American one. A guest will still hear "not quite local" — that is
# the sharpest regression from ElevenLabs, and the one paid line item worth
# considering if the accent matters commercially. Browse the rest at
# huggingface.co/rhasspy/piper-voices.
#
# THERE IS NO AMHARIC VOICE either. Piper does not have one and neither does Coqui,
# so the free stack cannot speak Amharic (see CLAUDE.md §0). Whisper still HEARS it.
PIPER_VOICE=/voices/en_GB-cori-medium.onnx

# ── The daily cron (api/sena/cron.mjs) ──────────────────────────────────────
# Vercel Cron sends this back as `Authorization: Bearer <CRON_SECRET>`. Without
# it the endpoint 401s — including when Vercel's own scheduler calls it — and
# nobody gets a pre-arrival reminder or a morning arrivals list.
# Generate the same way as SENA_WEBHOOK_SECRET.
CRON_SECRET=

# ── Paystack (ZAR) ──────────────────────────────────────────────────────────
# Test keys work immediately on signup — no business verification needed.
# The same key also verifies the webhook signature.
PAYSTACK_SECRET_KEY=sk_test_...
PAYSTACK_CALLBACK_URL=https://your-app.vercel.app/paid

# ── Supabase (front-desk scanner page only) ────────────────────────────────
# Project Settings → API. The ANON key is PUBLIC and safe to ship in the page:
# policies.sql grants it no policy at all, so it can read nothing. The clerk
# signs in with Supabase Auth, and the only thing they can then do is call
# sena_staff_check_in().
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=
