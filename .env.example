# ============================================================================
# Sena — environment. Copy to .env.local for local work; set the same keys in
# the Vercel project for production. NOTHING here is committed: .env* is ignored.
# ============================================================================

# ── Database ────────────────────────────────────────────────────────────────
# Supabase → Project Settings → Database → Connection string → URI.
# Use the POOLER (port 6543) connection, not the direct one: each Vercel
# invocation opens its own connection, and the direct port runs out.
DATABASE_URL=postgresql://postgres.xxxx:PASSWORD@aws-0-eu-west-1.pooler.supabase.com:6543/postgres

# Which hotel answers when the dialled number is not matched to a sena_hotels
# row. For the demo line, set this to the Jacaranda Court Hotel id:
#   select id from sena_hotels where is_demo;
# In production, leave it EMPTY — a hotel should be resolved by the number the
# guest actually dialled, never by a fallback.
SENA_DEFAULT_HOTEL_ID=

# Where this deployment is reachable. The guest's ID card link is built from it,
# so if it is wrong or empty the WhatsApp confirmation carries a number the guest
# cannot show to a scanner.
SENA_PUBLIC_URL=https://your-app.vercel.app

# ── Supabase (for the front desk page only) ─────────────────────────────────
# Project Settings → API. The ANON key is PUBLIC and safe to ship in the page:
# policies.sql grants it no policy at all, so it can read nothing. The clerk
# signs in with Supabase Auth, and the only thing they can then do is call
# sena_staff_check_in().
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=

# ── Vapi ────────────────────────────────────────────────────────────────────
# Any string, long and random. Goes in vapi-config.json as server.secret; Vapi
# sends it back on every tool call as the x-vapi-secret header.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SENA_WEBHOOK_SECRET=

# The ElevenLabs voice id Sena speaks with.
SENA_VOICE_ID=

# ── Paystack (ZAR) ──────────────────────────────────────────────────────────
# Start with the TEST key (sk_test_...). The same key verifies the webhook HMAC.
PAYSTACK_SECRET_KEY=
# Where Paystack sends the guest after they pay.
PAYSTACK_CALLBACK_URL=https://your-app.vercel.app/paid

# ── WhatsApp (Meta Cloud API) ───────────────────────────────────────────────
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=

# ── SMS fallback (Twilio) ───────────────────────────────────────────────────
# Used only when WhatsApp bounces. A payment link that never arrives is a
# booking the hotel loses while the guest is still on the line.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_SMS_FROM=+27...
